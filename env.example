# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (gpt-5, gpt-4o, gpt-4-turbo, etc.)
OPENAI_MODEL=gpt-5

# Server Configuration
PORT=3000
NODE_ENV=production

# CORS Configuration
CORS_ORIGIN=*

# Database Configuration (если понадобится в будущем)
# DATABASE_URL=your_database_url_here 